<clickhouse>
    <logger>
        <level>information</level>
        <console>1</console>
    </logger>
    
    <listen_host>0.0.0.0</listen_host>
    <interserver_http_port>9010</interserver_http_port>

    <!-- 资源限制 - 本地开发环境，数据量小，尽量省内存 -->
    <mark_cache_size>134217728</mark_cache_size>                 <!-- 128MB (默认5GB) -->
    <uncompressed_cache_size>0</uncompressed_cache_size>         <!-- 禁用，数据量小不需要 -->
    <max_server_memory_usage>0</max_server_memory_usage> <!-- 0=自动 -->
    <mlock_executable>false</mlock_executable>
    
    <!-- 线程池限制 -->
    <background_schedule_pool_size>4</background_schedule_pool_size>
    <background_pool_size>2</background_pool_size>
    <background_move_pool_size>1</background_move_pool_size>

    <merge_tree>
        <max_bytes_to_merge_at_max_space_in_pool>268435456</max_bytes_to_merge_at_max_space_in_pool>
        <max_bytes_to_merge_at_min_space_in_pool>134217728</max_bytes_to_merge_at_min_space_in_pool>
        <number_of_free_entries_in_pool_to_execute_mutation>1</number_of_free_entries_in_pool_to_execute_mutation>
        
        <!-- 配合 background_pool_size=4 的安全设置 -->
        <number_of_free_entries_in_pool_to_lower_max_size_of_merge>1</number_of_free_entries_in_pool_to_lower_max_size_of_merge>
        <number_of_free_entries_in_pool_to_execute_optimize_entire_partition>1</number_of_free_entries_in_pool_to_execute_optimize_entire_partition>
    </merge_tree>

    <!-- 禁用不需要的系统日志表，节省磁盘空间 -->
    <trace_log remove="1"/>
    <text_log remove="1"/>
    <query_thread_log remove="1"/>
    <query_log remove="1"/>
    <query_views_log remove="1"/>
    <metric_log remove="1"/>
    <asynchronous_metric_log remove="1"/>
    <opentelemetry_span_log remove="1"/>
    <session_log remove="1"/>
    <part_log remove="1"/>
    <crash_log remove="1"/>
    <processors_profile_log remove="1"/>
    <background_schedule_pool_log remove="1"/>
    <error_log remove="1"/>
    <query_metric_log remove="1"/>
    <asynchronous_insert_log remove="1"/>
    <backup_log remove="1"/>
    <s3queue_log remove="1"/>
    <blob_storage_log remove="1"/>
    <aggregated_zookeeper_log remove="1"/>
    <zookeeper_connection_log remove="1"/>
    <instrumentation_trace_log remove="1"/>
    <iceberg_metadata_log remove="1"/>
    <delta_lake_metadata_log remove="1"/>

</clickhouse>